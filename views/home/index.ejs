<h2>Home Page</h2>
<div style="display: flex; flex-wrap: wrap; gap: 20px; padding: 20px;">
  <% products.forEach(product => { %>
    <div style="border: 1px solid #ccc; border-radius: 8px; padding: 10px; width: 300px;">
      <img src="<%= product.imageUrl %>" alt="<%= product.name %>" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px;" />
      <h3><%= product.name %></h3>
      <p><%= product.desc %></p>
      <h4>$<%= product.price %></h4>
      <p style="margin: 8px 0 0;">
        🌟<strong>Rating:</strong> <%= product.rating != null ? product.rating : "N/A" %>
      </p>
    </div>
  <% }) %>
</div>