<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="form-page">
      <h2 class="admin-title">Add Product Form</h2>
      <form class="form-card" action="/products/add" method="POST">
        <p><input type="text" name="name" placeholder="Product Name" /></p>
        <p><input type="number" name="price" placeholder="Price" /></p>
        <p><input type="text" name="desc" placeholder="Description" /></p>
        <p><input type="text" name="imageUrl" placeholder="Image Url" /></p>
        <p><input type="number" name="rating" placeholder="Rating" min="1" step="0.01"/></p>
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Add Product</button>
          <a class="btn btn-edit" href="/products">Back</a>
        </div>
      </form>
    </div>
  </body>
</html>