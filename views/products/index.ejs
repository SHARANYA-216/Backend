<h2>Products Admin Page</h2>

<p><a href="/products/add">Add Product</a></p>

<ol>
	<% if (!products || products.length === 0) { %>
		<li>No products found.</li>
	<% } %>

	<% if (products && products.length > 0) { %>
		<% products.forEach((product) => { %>
			<li>
				<%= product.name %> - <%= product.desc %> - <%= product.price %> - <%= product.imageUrl %>
				| <a href="/products/<%= product._id %>/edit">Edit</a>
				| <a href="/products/<%= product._id %>/delete" onclick="return confirm('Delete this product?')">Delete</a>
			</li>
		<% }) %>
	<% } %>
</ol>
