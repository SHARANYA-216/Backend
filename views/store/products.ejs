<h1>Products Page</h1>

<div class="row">
  <% if (!products || products.length === 0) { %>
    <p>No products found.</p>
  <% } %>

  <% if (products && products.length > 0) { %>
    <% products.forEach((product) => { %>
      <div class="box">
        <img src="<%= product.imageUrl %>" width="250px" />
        <h2><%= product.name %></h2>
        <p><%= product.desc %></p>
        <h4><%= product.price %></h4>
      </div>
    <% }) %>
  <% } %>
</div>